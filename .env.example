# ============================================================
# RAYA STUDIO — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Conexão com o banco de dados Supabase (obrigatório)
DATABASE_URL=postgresql://postgres:[SENHA]@db.[PROJECT_ID].supabase.co:5432/postgres

# Segredo para criptografia das sessões (obrigatório)
# Gere uma string aleatória longa — ex: openssl rand -hex 32
SESSION_SECRET=

# Ambiente da aplicação
NODE_ENV=development

# Porta do servidor (opcional, padrão: 5000)
PORT=5000

# Credenciais do usuário admin (obrigatório no primeiro deploy)
ADMIN_EMAIL=
ADMIN_PASSWORD=
