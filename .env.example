# ============================================================
# RAYA STUDIO - Variaveis de Ambiente
# ============================================================

# Desenvolvimento local: use o Postgres do docker-compose na porta 5434
DATABASE_URL=postgresql://raya:raya_dev_password@localhost:5434/raya
DATABASE_SSL=false

# Docker Compose variables
POSTGRES_USER=raya
POSTGRES_PASSWORD=raya_dev_password
POSTGRES_DB=raya

# Segredo para criptografia das sessoes
# Gere uma string aleatoria longa em producao
SESSION_SECRET=raya-dev-session-secret-change-me

# Usuario inicial sincronizado no seed
ADMIN_USERNAME=adm@raya.local
ADMIN_PASSWORD=raya-dev-password

# Ambiente da aplicacao
NODE_ENV=development

# Porta do servidor
PORT=5000

# URL pública do app em produção, usada para montar URLs absolutas quando necessário
PUBLIC_BASE_URL=https://app.seudominio.com

# Migrações Drizzle rodam no boot de produção por padrão
RUN_MIGRATIONS=true

# Limite de chamadas aos endpoints de IA por minuto
AI_RATE_LIMIT_PER_MINUTE=20

# Storage de imagens geradas
# Se S3_BUCKET não for definido, o app usa storage local em /uploads/generated
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
